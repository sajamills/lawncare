NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_placeholder
CLERK_SECRET_KEY=sk_test_placeholder

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding/1

# Postgres — choose one option below:
#
# Option A — Vercel Postgres (Neon via Vercel Marketplace):
#   1. Go to vercel.com → your project → Storage → Add → Neon Postgres
#   2. Run: vercel env pull .env.local
#   (Vercel auto-populates POSTGRES_URL and related vars)
#
# Option B — Supabase:
#   1. Create a project at supabase.com
#   2. Go to Settings → Database → Connection string → Transaction mode
#   3. Copy the URI and paste below (replace [YOUR-PASSWORD])
#   POSTGRES_URL=postgres://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
#
# After setting POSTGRES_URL, run: npm run db:migrate
POSTGRES_URL=postgres://user:password@host:5432/dbname
